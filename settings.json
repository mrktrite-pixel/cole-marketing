{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "agents": {
    "cole-orchestrator-queen": {
      "model": "claude-opus-4-6"
    },
    "strategic-queen": {
      "model": "claude-opus-4-6"
    }
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run build)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(curl *)",
      "Bash(node *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  }
}
